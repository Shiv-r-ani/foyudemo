<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8F3">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Back + Title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_media_previous"
                android:background="#1A3E2723"
                android:padding="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Complete Booking"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#3E2723"
                android:layout_marginStart="12dp"/>
        </LinearLayout>

        <!-- Service Summary Card -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#3E2723">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="You selected"
                    android:textColor="#FFDDBB"
                    android:textSize="12sp"/>

                <TextView
                    android:id="@+id/tvServiceSummary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Service — Package (₹000)"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Section Label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Schedule"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#3E2723"
            android:layout_marginBottom="12dp"/>

        <!-- Date -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📅  Preferred Date"
            android:textSize="13sp"
            android:textColor="#555555"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etDate"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Tap to pick a date"
            android:focusable="false"
            android:clickable="true"
            android:background="@drawable/input_bg"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textSize="14sp"
            android:layout_marginBottom="16dp"
            android:inputType="none"/>

        <!-- Time -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🕐  Preferred Time"
            android:textSize="13sp"
            android:textColor="#555555"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etTime"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Tap to pick a time"
            android:focusable="false"
            android:clickable="true"
            android:background="@drawable/input_bg"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textSize="14sp"
            android:layout_marginBottom="24dp"
            android:inputType="none"/>

        <!-- Section Label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Details"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#3E2723"
            android:layout_marginBottom="12dp"/>

        <!-- Address -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📍  Service Address"
            android:textSize="13sp"
            android:textColor="#555555"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etAddress"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:hint="House no., Street, Area, City"
            android:background="@drawable/input_bg"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="12dp"
            android:gravity="top"
            android:textSize="14sp"
            android:inputType="textMultiLine"
            android:layout_marginBottom="16dp"/>

        <!-- Phone -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📞  Phone Number"
            android:textSize="13sp"
            android:textColor="#555555"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etPhone"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="10-digit mobile number"
            android:background="@drawable/input_bg"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textSize="14sp"
            android:inputType="phone"
            android:maxLength="10"
            android:layout_marginBottom="32dp"/>

        <!-- Confirm Button -->
        <Button
            android:id="@+id/btnConfirmBooking"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Confirm Booking"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#3E2723"/>

    </LinearLayout>
</ScrollView>