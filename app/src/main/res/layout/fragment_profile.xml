<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8F3">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="My Profile"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="20dp"/>

        <!-- Local Room Data -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Account Info (Local)"
            android:textSize="13sp"
            android:textColor="@color/black"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/search_bg"
            android:padding="20dp"
            android:layout_marginBottom="20dp">

            <TextView android:text="Name" android:textSize="12sp"
                android:textColor="@color/black"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:id="@+id/tvName" android:text="—"
                android:textSize="18sp" android:textStyle="bold"
                android:textColor="@color/black"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"/>

            <TextView android:text="Email" android:textSize="12sp"
                android:textColor="@color/black"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:id="@+id/tvEmail" android:text="—"
                android:textSize="18sp" android:textStyle="bold"
                android:textColor="@color/black"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"/>

            <TextView android:text="Phone" android:textSize="12sp"
                android:textColor="@color/black"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:id="@+id/tvPhone" android:text="—"
                android:textSize="18sp" android:textStyle="bold"
                android:textColor="@color/black"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Retrofit Data -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="From API (Retrofit)"
            android:textSize="13sp"
            android:textColor="@color/black"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/search_bg"
            android:padding="20dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/tvLoading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loading from API..."
                android:textColor="@color/black"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"/>

            <TextView android:id="@+id/tvRetrofitName" android:text=""
                android:textSize="16sp" android:textStyle="bold"
                android:textColor="@color/black"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"/>

            <TextView android:id="@+id/tvRetrofitEmail" android:text=""
                android:textSize="16sp"
                android:textColor="@color/black"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Logout"
            android:backgroundTint="#5D4037"
            android:textColor="@color/white"
            android:textSize="16sp"/>

    </LinearLayout>
</ScrollView>